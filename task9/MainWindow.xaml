<Window x:Class="task9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:task9.ViewModels"
        Title="Phone Book MVVM" Height="450" Width="400">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Имя:"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <TextBlock Text="Телефон:"/>
            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <Button Content="Добавить контакт" Command="{Binding AddCommand}" Margin="0,0,0,5"/>
            <Button Content="Удалить выбранный" Command="{Binding DeleteCommand}" 
                    CommandParameter="{Binding SelectedContact}" Margin="0,0,0,10"/>

            <DataGrid ItemsSource="{Binding Contacts}" SelectedItem="{Binding SelectedContact}" 
                      AutoGenerateColumns="False" Height="250" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Window>