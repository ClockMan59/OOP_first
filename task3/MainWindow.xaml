<Window x:Class="task3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Паттерн: Абстрактная фабрика" Height="300" Width="450">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ComboBox x:Name="ColorComboBox" SelectionChanged="ComboBox_SelectedIndexChanged" Width="150" HorizontalAlignment="Left" Margin="10">
            <ComboBoxItem Content="Красный"/>
            <ComboBoxItem Content="Синий"/>
            <ComboBoxItem Content="Зелёный"/>
        </ComboBox>

        <StackPanel x:Name="DrawingPanel" Grid.Row="1" Orientation="Horizontal" Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>