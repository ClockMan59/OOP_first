<UserControl x:Class="task11.Views.ContactEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<StackPanel Margin="20">
		<TextBlock Text="Редактирование контакта" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
		<TextBlock Text="Имя:"/>
		<TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>
		<TextBlock Text="Телефон:"/>
		<TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" Padding="5"/>

		<Button Content="Сохранить и вернуться" Command="{Binding SaveCommand}" Padding="10"/>
	</StackPanel>
</UserControl>