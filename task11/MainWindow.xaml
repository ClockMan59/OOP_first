<Window x:Class="task11.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:task11.ViewModels"
        xmlns:v="clr-namespace:task11.Views"
        Title="Телефонная книга Shell" Height="450" Width="500">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ContactsListViewModel}">
            <v:ContactsListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <v:AboutView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#EEE">
            <Button Content="Список контактов" Command="{Binding ShowContactsCommand}" Margin="0,0,10,0" Padding="10,5"/>
            <Button Content="О программе" Command="{Binding ShowAboutCommand}" Padding="10,5"/>
        </StackPanel>

        <ContentControl Content="{Binding NavigationService.CurrentViewModel}" Margin="10"/>
    </DockPanel>
</Window>