<Window x:Class="task10.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Телефонная книга (Task 10 - DI &amp; Services)" Height="450" Width="400">

    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Имя контакта:"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

            <TextBlock Text="Номер телефона:"/>
            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

            <Button Content="Добавить контакт" Command="{Binding AddCommand}" Margin="0,0,0,5" Padding="5"/>
            <Button Content="Удалить выбранный" Command="{Binding DeleteCommand}" 
                    CommandParameter="{Binding SelectedContact}" Margin="0,0,0,10" Padding="5"/>

            <DataGrid ItemsSource="{Binding Contacts}" SelectedItem="{Binding SelectedContact}" 
                      AutoGenerateColumns="False" Height="230" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Window>